// NGECEK JADWAL YG BENTROKAN SEBELUM DI UBAH DAN SESUDAH DI UBAH
func cekBentrok(tab DaftarSewa, jumlah int, idLapangan int, tanggal string, jamMulai int, jamSelesai int) bool {
	var i int
	var bentrok bool

	i = 0
	bentrok = false
	for i < jumlah && !bentrok {
		if tab[i].IdLapangan == idLapangan && tab[i].Tanggal == tanggal {
			if jamMulai < tab[i].JamSelesai && jamSelesai > tab[i].JamMulai {
				bentrok = true
			}
		}
		i++
	}
	return bentrok
}

func cekBentrokUbah(tab DaftarSewa, jumlah int, idSewa int, idLapangan int, tanggal string, jamMulai int, jamSelesai int) bool {
	var i int
	var bentrok bool

	i = 0
	bentrok = false
	for i < jumlah && !bentrok {
		if tab[i].Id != idSewa && tab[i].IdLapangan == idLapangan && tab[i].Tanggal == tanggal {
			if jamMulai < tab[i].JamSelesai && jamSelesai > tab[i].JamMulai {
				bentrok = true
			}
		}
		i++
	}
	return bentrok
}

func tambahDataSewa(dataLapangan DaftarLapangan, jumlahLapangan int, dataPenyewa DaftarSewa, jumlahPenyewa int, dataSewa *DaftarSewa, jumlahSewa *int) {
	var sewaBaru DataSewa
	var posisiLapangan, posisiPenyewa, posisiSewa int
	var durasi, pilihanBayar int
	var bentrok bool  

	if *jumlahSewa >= NMAX {
		fmt.Println("Data sewa sudah penuh.")
	} else {
		fmt.Println("==== TAMBAH DATA SEWA ====")
		fmt.Print("Masukkan ID sewa: ")
		fmt.Scan(&sewaBaru.Id)

		posisiSewa = cariDataSewa(*dataSewa, *jumlahSewa, sewaBaru.Id)
		if posisiSewa != -1 {
			fmt.Println("ID sewa sudah digunakan.")
		} else {
			fmt.Print("Masukkan ID penyewa: ")
			fmt.Scan(&sewaBaru.IdPenyewa)

			posisiPenyewa = cariPenyewa(dataPenyewa, jumlahPenyewa, sewaBaru.IdPenyewa)
			if posisiPenyewa == -1 {
				fmt.Println("ID penyewa tidak ditemukan.")
			} else {
				fmt.Print("Masukkan ID lapangan: ")
				fmt.Scan(&sewaBaru.IdLapangan)
				
				posisiLapangan = cariLapangan(dataLapangan, jumlahLapangan, sewaBaru.IdLapangan)
				if posisiLapangan == -1 {
					fmt.Println("ID lapangan tidak ditemukan.")
				} else {
					fmt.Print("Masukkan tanggal sewa YYYY-MM-DD: ")
					fmt.Scan(&sewaBaru.Tanggal)
					fmt.Print("Masukkan jam mulai HH:MM, contoh 09:35: ")
					sewaBaru.JamMulai = inputJam()
					fmt.Print("Masukkan jam selesai HH:MM, contoh 11:00: ")
					sewaBaru.JamSelesai = inputJam()

					if sewaBaru.JamMulai == -1 || sewaBaru.JamSelesai == -1 {
						fmt.Println("Format jam tidak valid.")
					} else if sewaBaru.JamMulai < JAM_BUKA || sewaBaru.JamSelesai > JAM_TUTUP {
						fmt.Println("Jam sewa di luar jam operasional.")
					} else if sewaBaru.JamSelesai <= sewaBaru.JamMulai {
						fmt.Println("Jam sewa tidak valid.")
					} else {
						bentrok = cekBentrok(*dataSewa, *jumlahSewa, sewaBaru.IdLapangan, sewaBaru.Tanggal, sewaBaru.JamMulai, sewaBaru.JamSelesai)
						if bentrok {
							fmt.Println("Jadwal sudah terbooking.")
						} else {
							sewaBaru.HargaPerJam = dataLapangan[posisiLapangan].HargaPerJam
							durasi = sewaBaru.JamSelesai - sewaBaru.JamMulai
							sewaBaru.TotalBayar = durasi * sewaBaru.HargaPerJam / 60
							sewaBaru.StatusTersedia = false 
							sewaBaru.NamaPenyewa = dataPenyewa[posisiPenyewa].NamaPenyewa
							sewaBaru.NoTelp = dataPenyewa[posisiPenyewa].NoTelp
							
							fmt.Println("Total bayar:", sewaBaru.TotalBayar)
							fmt.Print("Status bayar 1 = Lunas, 2 = Belum_Lunas: ")
							fmt.Scan(&pilihanBayar)

							if pilihanBayar == 1 {
								sewaBaru.StatusBayar = true 
							} else {
								sewaBaru.StatusBayar = false
							}

							dataSewa[*jumlahSewa] = sewaBaru
							*jumlahSewa = *jumlahSewa + 1
							fmt.Println("Data sewa berhasil ditambahkan.")
						}
					}
				}
			}
		}	
	}
}

