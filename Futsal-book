func jamPalingSeringDipesan(tab DaftarSewa, jumlah int) {
	var frekuensi [24 * 60]int
	var i, jam, jamFavorit, jumlahTerbanyak int

	i = 0
	for i < jumlah {
		jam = tab[i].JamMulai
		if jam >= 0 && jam < 24 * 60 {
			frekuensi[jam] = frekuensi[jam] + 1
		}
		i++
	}

	jamFavorit = -1
	jumlahTerbanyak = 0
	i = 0
	for i < 24 * 60 {
		if frekuensi[i] > jumlahTerbanyak {
			jumlahTerbanyak = frekuensi[i]
			jamFavorit = i 
		}
		i++
	}

	fmt.Println("==== JAM PALING SERING DIPESAN ====")
	if jamFavorit == -1 {
		fmt.Println("Belum ada data pemesanan.")
	} else {
		fmt.Print("Jam paling sering dipesan: ")
		cetakJam(jamFavorit)
		fmt.Println()
		fmt.Println("Jumlah pemesanan:", jumlahTerbanyak)
	}
}

