// FITUR BAGIAN C : MENGURUTKAN JADWAL KOSONG BERDASARKAN JAM MULAI/HARGA SEWA MENGGUNAKAN SELECTION DAN INSERTION SORT

func selectsortJadwaljam(tab *DaftarSewa, jumlah int) {
	var pass, i, idx int
	var temp DataSewa

	pass = 1
	for pass <= jumlah-1 {
		idx = pass - 1
		i = pass
		for i < jumlah {
			if tab[i].JamMulai < tab[idx].JamMulai || 
			(tab[i].JamMulai == tab[idx].JamMulai && tab[i].HargaPerJam < tab[idx].HargaPerJam) {
				idx = i 
			}
			i++
		}
		temp = tab[pass-1]
		tab[pass-1] = tab[idx]
		tab[idx] = temp 
		pass = pass + 1
	}
}

func insertsortJadwalHarga(tab *DaftarSewa, jumlah int) {
	var pass, i int
	var temp DataSewa

	pass = 1
	for pass <= jumlah-1 {
		i = pass
		temp = tab[pass]
		for i > 0 && 
		(temp.HargaPerJam < tab[i-1].HargaPerJam || 
			(temp.HargaPerJam == tab[i-1].HargaPerJam && temp.JamMulai < tab[i-1].JamMulai)) {
			tab[i] = tab[i-1]
			i--
		}
		tab[i] = temp
		pass = pass + 1
	}
}

