			menuKelolaData(&dataLapangan, &jumlahLapangan, &dataPenyewa, &jumlahPenyewa, dataSewa, jumlahSewa)
		} else if pilihan == 2 {
			menuTransaksi(dataLapangan, jumlahLapangan, dataPenyewa, jumlahPenyewa, &dataSewa, &jumlahSewa)
		} else if pilihan == 3 {
			menuPencarian(dataPenyewa, jumlahPenyewa)
		} else if pilihan == 4 {
			menuUrutJadwalKosong(dataLapangan, jumlahLapangan, dataSewa, jumlahSewa)
		} else if pilihan == 5 {
			menuStatistik(dataSewa, jumlahSewa)
		} else if pilihan == 0 {
			selesai = true 
		} else {
			fmt.Println("Pilihan tidak valid.")
		}
		fmt.Println()
	}
}