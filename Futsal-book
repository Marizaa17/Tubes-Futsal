// Karena yg dicari binary search maka kita urutkan menggunakan selectionsort terlebih dahulu
func selectsortNamaPenyewa(tab *DaftarSewa, jumlah int) {
	var pass, i, idx int
	var temp DataSewa

	pass = 1
	for pass <= jumlah-1 {
		idx = pass -1
		i = pass 
		for i < jumlah {
			if tab[i].NamaPenyewa < tab[idx].NamaPenyewa {
				idx = i 
			}
			i++
		}
		temp = tab[pass-1]
		tab[pass-1] = tab[idx]
		tab[idx] = temp
		pass = pass + 1
	}
}

func selectsortTeleponPenyewa(tab *DaftarSewa, jumlah int) {
	var pass, i, idx int
	var temp DataSewa

	pass = 1
	for pass <= jumlah-1 {
		idx = pass -1
		i = pass
		for i < jumlah {
			if tab[i].NoTelp < tab[idx].NoTelp {
				idx = i
			}
			i++
		} 
		temp = tab[pass-1]
		tab[pass-1] = tab[idx]
		tab[idx] = temp
		pass = pass + 1
	}
}

func binarysearchNama(tab DaftarSewa, jumlah int, namaCari string) int {
	var kiri, kanan, tengah, posisi int

	selectsortNamaPenyewa(&tab, jumlah)
	kiri = 0
	kanan = jumlah - 1
	posisi = -1
	for kiri <= kanan && posisi == -1 {
		tengah = (kiri + kanan) / 2
		if namaCari < tab[tengah].NamaPenyewa {
			kanan = tengah - 1
		} else if namaCari > tab[tengah].NamaPenyewa {
			kiri = tengah + 1
		} else {
			posisi = tengah 
		}
	}
	if posisi != -1 {
		tampilanSatuPenyewa(tab[posisi])
	}
	return posisi
}

