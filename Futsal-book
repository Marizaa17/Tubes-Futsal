func buatJadwalKosong(dataLapangan DaftarLapangan, jumlahLapangan int, dataSewa DaftarSewa, jumlahSewa int, tanggal string, jadwalKosong *DaftarSewa, jumlahKosong *int) {
	var i, jamMulai, jamSelesai int
	var bentrok bool
	var dataKosong DataSewa

	*jumlahKosong = 0
	i = 0
	for i < jumlahLapangan {
		jamMulai = JAM_BUKA
		for jamMulai + SLOT_JADWAL <= JAM_TUTUP {
			jamSelesai = jamMulai + SLOT_JADWAL
			bentrok = cekBentrok(dataSewa, jumlahSewa, dataLapangan[i].IdLapangan, tanggal, jamMulai, jamSelesai)

			if !bentrok {
				dataKosong.Id = 0 
				dataKosong.IdPenyewa = 0
				dataKosong.IdLapangan = dataLapangan[i].IdLapangan
				dataKosong.NamaPenyewa = "-"
				dataKosong.NoTelp = "-"
				dataKosong.Tanggal = tanggal
				dataKosong.JamMulai = jamMulai
				dataKosong.JamSelesai = jamSelesai
				dataKosong.HargaPerJam = dataLapangan[i].HargaPerJam
				dataKosong.TotalBayar = SLOT_JADWAL * dataKosong.HargaPerJam / 60
				dataKosong.StatusTersedia = true
				dataKosong.StatusBayar = false

				jadwalKosong[*jumlahKosong] = dataKosong
				*jumlahKosong = *jumlahKosong + 1
			}
			jamMulai =jamMulai + SLOT_JADWAL
		}
		i++
	}
}

