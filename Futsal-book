func inputJam() int {
	var teks string
	var jam, menit int

	fmt.Scan(&teks)
	jam = int(teks[0]-'0')*10 + int(teks[1]-'0') 
	menit = int(teks[3]-'0')*10 + int(teks[4]-'0') 

	if teks[2] != ':' || jam < 0 || jam > 23 || menit < 0 || menit > 59 {
		return -1
	}
	return jam*60 + menit
}

func cetakDuaDigit(angka int) {
	if angka < 10 {
		fmt.Print("0")
	}
	fmt.Print(angka)
}

// agar format jam nya jadi HH:MM 
func cetakJam(totalmenit int) {
	cetakDuaDigit(totalmenit / 60)
	fmt.Print(":")
	cetakDuaDigit(totalmenit % 60)
}

